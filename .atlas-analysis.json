  "keyFeatures": [
    "Student registration with representative contact info and section assignment",
    "Teacher registration with academic credentials and load assignment",
    "Academic year and section management with guide teacher assignment",
    "Subject catalog and study plan configuration per grade level",
    "Daily and monthly student attendance tracking with per-subject detail",
    "Teacher attendance recording",
    "Bulk import of students and teachers from Excel files",
    "PDF and Excel export of reports",
    "Real-time data updates using Next.js Server Actions and cache revalidation"
  ],
  "publicApiSurface": [
    "agregarEstudiante(data: EstudianteData)",
    "actualizarEstudiante(cedula: string, data: EstudianteData)",
    "borrarEstudiante(cedula: string)",
    "asignarSeccionEstudiante(estudianteId: string, seccionId: number | null)",
    "importarEstudiantes(estudiantes: any[])",
    "agregarDocente(data: DocenteData)",
    "actualizarDocente(id: number, data: DocenteData)",
    "borrarDocente(id: number)",
    "asignarCargaDocente(docenteId: number, seccionId: number, materiaId: string)",
    "importarDocentes(docentes: any[])",
    "agregarAnio(formData: FormData)",
    "agregarSeccion(formData: FormData)",
    "actualizarSeccion(id: number, formData: FormData)",
    "agregarMateria(formData: FormData)",
    "actualizarMateria(id: string, formData: FormData)",
    "asignarCarga(formData: FormData)",
    "removerCarga(id: number)",
    "borrarMateria(id: string)",
    "guardarAsistenciaDiaria(fecha: Date, datosAsistencia: AsistenciaDiaria[])",
    "guardarCambiosAsistencia(cambios: CambioAsistencia[])"
  ]
}
