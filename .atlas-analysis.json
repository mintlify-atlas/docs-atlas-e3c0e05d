  "projectName": "Proyecto Colegio",
  "projectDescription": "A full-stack school management system for managing students, teachers, academic structure, and attendance records.",
  "theme": "almond",
  "primaryColor": "#7c7c7c",
  "lightColor": "#080808",
  "darkColor": "#c1c1c1",
